# Build context exclusions — keeps context minimal and prevents secret leakage

# Version control
.git
.gitignore
.github

# Dependencies — reinstalled inside container via npm ci
node_modules

# Build output — regenerated by npm run build in builder stage
dist
build

# Editor / IDE
.vscode
.idea
*.swp
*.swo
.editorconfig

# OS
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test / coverage
coverage
.nyc_output
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
__tests__
__mocks__
vitest.config.*
jest.config.*

# Docker build files — self-referential, not needed inside the image
# nginx.conf is intentionally absent: COPY in Stage 3 requires it in context
Dockerfile
Dockerfile.*
.dockerignore

# Secrets
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
secrets/
.secret
.secrets

# Temp / cache
.cache
.tmp
tmp/
temp/
.turbo

# Docs
README.md
LICENSE
docs/

# CI/CD
.github
.gitlab-ci.yml
Jenkinsfile
.circleci
.travis.yml
azure-pipelines.yml
