# =============================================================================
# .dockerignore — portfolio-site
# Purpose: Exclude everything not required for `docker build`.
# Benefits: (1) smaller build context → faster transfer to Docker daemon
#           (2) no accidental secret/credential leakage into image layers
#           (3) prevents local node_modules from clobbering deps stage output
# =============================================================================

# ── Version Control ───────────────────────────────────────────────────────────
.git
.gitignore
.github

# ── Dependencies ──────────────────────────────────────────────────────────────
# MUST be excluded. If a local node_modules exists and this line is missing,
# `COPY . .` would overwrite the clean `npm ci` output from the deps stage.
# The deps stage re-installs everything fresh inside the container.
node_modules

# ── Build Output ──────────────────────────────────────────────────────────────
# dist/ is regenerated by `npm run build` inside the builder stage.
# Excluding it prevents a stale local build from entering the context.
dist
build

# ── Editor & IDE Artifacts ────────────────────────────────────────────────────
.vscode
.idea
*.swp
*.swo
.editorconfig

# ── OS Artifacts ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Test & Coverage Artifacts ─────────────────────────────────────────────────
coverage
.nyc_output
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
__tests__
__mocks__
vitest.config.*
jest.config.*

# ── Docker Files (prevent recursive self-inclusion) ───────────────────────────
Dockerfile
Dockerfile.*
.dockerignore
nginx.conf

# ── Secrets & Credentials (NEVER bake into an image layer) ───────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
secrets/
.secret
.secrets

# ── Temporary & Cache Directories ─────────────────────────────────────────────
.cache
.tmp
tmp/
temp/
.turbo

# ── Documentation (not needed in runtime image) ───────────────────────────────
README.md
LICENSE
docs/

# ── CI/CD Pipeline Config (not needed inside container) ───────────────────────
.github
.gitlab-ci.yml
Jenkinsfile
.circleci
.travis.yml
azure-pipelines.yml
